{
  "title": "Llama.cpp",
  "description": "A lightning-fast Llama.cpp Worker",
  "type": "serverless",
  "category": "language",
  "iconUrl": "https://raw.githubusercontent.com/ggml-org/llama.brand/refs/heads/master/cover/llama-cpp/cover-llama-cpp-light.svg",
  "config": {
    "runsOn": "GPU",
    "gpuCount": 1,
    "gpuIds": "AMPERE_16,AMPERE_24,ADA_24",
    "containerDiskInGb": 25,
    "presets": [],
    "env": [
      {
        "key": "LLAMA_ARG_HF_REPO",
        "input": {
          "name": "Model HF repo",
          "type": "string",
          "description": "Hugging Face model repository; quant is optional, case-insensitive, default to Q4_K_M, <user>/<model>[:quant]",
          "default": "unsloth/Qwen3.5-9B-MTP-GGUF:UD-Q4_K_XL",
          "advanced": false
        }
      },
      {
        "key": "LLAMA_ARG_ALIAS",
        "input": {
          "name": "Model alias",
          "type": "string",
          "description": "Alias for the model",
          "default": "qwen3.5-9b",
          "advanced": false
        }
      },
      {
        "key": "MAX_CONCURRENCY",
        "input": {
          "name": "Max Concurrency",
          "type": "number",
          "description": "Maximum number of concurrent requests to handle (default: 4)",
          "default": 4,
          "advanced": true
        }
      },
      {
        "key": "LLAMA_NUM_PARALLEL",
        "input": {
          "name": "Parallel Requests",
          "type": "string",
          "description": "Maximum number of concurrent requests to handle (default: 4 or 1)",
          "default": 4,
          "advanced": true
        }
      }
    ]
  }
}