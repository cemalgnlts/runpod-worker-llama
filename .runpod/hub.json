{
  "title": "Runpod Worker Llama.cpp",
  "description": "A serverless Llama.cpp Worker for Runpod",
  "type": "serverless",
  "category": "language",
  "iconUrl": "https://llama-cpp.com/wp-content/uploads/2025/10/Llama-cpp-768x277.jpg",
  "config": {
    "runsOn": "GPU",
    "gpuCount": 1,
    "gpuIds": "AMPERE_16,AMPERE_24,ADA_24",
    "containerDiskInGb": 20,
    "presets": [],
    "env": [
      {
        "key": "MODEL_REPO",
        "input": {
          "name": "Model HF repo",
          "type": "string",
          "description": "Hugging face repo for model",
          "default": "unsloth/Qwen3.5-9B-MTP-GGUF",
          "advanced": false
        }
      },
      {
        "key": "MODEL_FILE",
        "input": {
          "name": "Model gguf file",
          "type": "string",
          "description": "Model file name",
          "default": "Qwen3.5-9B-MTP-UD-Q4_K_XL.gguf",
          "advanced": false
        }
      },
      {
        "key": "LLAMA_ARG_ALIAS",
        "input": {
          "name": "Model alias",
          "type": "string",
          "description": "Model alias name",
          "default": "qwen3.5-9b",
          "advanced": false
        }
      },
      {
        "key": "MAX_CONCURRENCY",
        "input": {
          "name": "Max Concurrency",
          "type": "number",
          "description": "Maximum number of concurrent requests to handle (default: 8)",
          "default": 8,
          "advanced": true
        }
      },
      {
        "key": "LLAMA_NUM_PARALLEL",
        "input": {
          "name": "Parallel Requests",
          "type": "string",
          "description": "Maximum number of concurrent requests to handle (default: 4 or 1)",
          "default": 4,
          "advanced": true
        }
      }
    ]
  }
}